{
  "version": "2026-06-27-sprint1-3",
  "last_update_agent": "SecurityAG",
  "updated_at": "2026-06-27",
  "rules": [
    {
      "id": "BR-001-voice-mic",
      "agent": "CoderAG",
      "sprint": 1,
      "feature": "voice_input_mic_permission",
      "status": "WHITELISTED_ON_DEMAND",
      "permissions": {
        "web_speech_api": "allow",
        "navigator.mediaDevices.getUserMedia": "allow_with_constraint"
      },
      "constraints": {
        "domain_whitelist": ["demo-domain-only", "no_wildcard"],
        "fallback_on_permission_denied": "graceful_text_only_mode",
        "no_silent_fail": true
      },
      "risk_score": "5/10 MITTEL",
      "review_required": false
    },
    {
      "id": "BR-002-houdini-css",
      "agent": "CoderAG",
      "sprint": 2,
      "feature": "houdini_css_paint_api",
      "status": "WHITELISTED_ON_DEMAND_WITH_LOCKS",
      "permissions": {
        "css_paint_api": "allow",
        "custom_css_user_input": "FORBIDDEN"
      },
      "locks": {
        "csp_header": "script-src self (LOCKED — kein unsafe-inline, kein unsafe-eval)",
        "user_input_in_custom_css": "FORBIDDEN",
        "rendering_pipeline": "keine User-Inputs in Custom-CSS-Snippets rendern"
      },
      "risk_score": "3/10 NIEDRIG",
      "review_required": false
    },
    {
      "id": "BR-003-sprint3-gdpr-gate",
      "agent": "WriterAG",
      "sprint": 3,
      "feature": "eye_tracking_report",
      "status": "GATE_BLOCKED",
      "blocker": "GDPR_DSGVO_SECTION_MISSING",
      "unblock_condition": "SecurityAG_approval_post_review",
      "required_gdpr_content": [
        "Datenminimierung",
        "Auftragsverarbeiter-Vertrag-Hinweis",
        "Cookie-Consent-Logik",
        "Auskunftsrecht (Art. 15 DSGVO)"
      ],
      "sla_security_review": "unter 24h nach Draft-Abgabe",
      "precondition": "Research-Feed VOR Sprint-3-Start",
      "risk_score": "7/10 HOCH",
      "publish_allowed": false
    },
    {
      "id": "BR-004-sequence",
      "agent": "all",
      "type": "sequencing",
      "rule": "Sprint 1 → Sprint 2 → Sprint 3",
      "sprint_1_2": "on_demand_whitelist",
      "sprint_3": "gate_pflicht"
    },
    {
      "id": "BR-005-caniuse-pflicht",
      "agent": "WriterAG",
      "type": "documentation_standard",
      "rule": "CanIUse-Datum in allen Browser-API-Dokumenten Pflicht"
    }
  ],
  "model_routing": {
    "CoderAG_sprint1_2": "coder-model-default",
    "WriterAG_sprint3": "writer-model-with-gdpr-context",
    "SecurityAG_review": "security-model-default"
  }
}